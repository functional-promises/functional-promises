{
  "exclude": ["dist", "tests", "misc", "docs", "docs-source", "coverage", "node_modules"],
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "declaration": false,
    "noEmit": true,
    "pretty": true,
    "lib": [
      "ES2022",
      "DOM"
    ]
  }
}
